.pilot-container
    .pilot-header
        .pilot-title
            i.fas.fa-robot.me-2
            strong Pilot Chat
            span.badge.bg-secondary.ms-2 {{providerLabel}}
        .pilot-actions
            button.btn.btn-sm.btn-link((click)='newChat()', title='New Chat')
                i.fas.fa-plus
            button.btn.btn-sm.btn-link((click)='clearChat()', title='Clear Chat')
                i.fas.fa-trash
            button.btn.btn-sm.btn-link((click)='closeSidebar()', title='Close Sidebar')
                i.fas.fa-times

    .pilot-messages
        .message(*ngFor='let message of messages', [class.user-message]='message.role === "user"', [class.assistant-message]='message.role === "assistant"')
            .message-header
                i.fas.fa-user(*ngIf='message.role === "user"')
                i.fas.fa-robot(*ngIf='message.role === "assistant"')
                span.message-role {{message.role === 'user' ? 'You' : 'Assistant'}}
            
            // 如果有 parts，按顺序渲染；否则显示 content
            ng-container(*ngIf='message.parts && message.parts.length > 0; else simpleContent')
                ng-container(*ngFor='let part of message.parts')
                    .message-content(*ngIf='part.type === "text"') {{part.text}}
                    .tool-execution(*ngIf='part.type === "tool-call" && part.toolCall')
                        .tool-header
                            i.fas.fa-terminal.me-2
                            strong Execute Shell Command
                        .tool-command
                            code {{part.toolCall.args.command}}
                        .tool-actions(*ngIf='part.toolCall.status === "pending"')
                            button.btn.btn-sm.btn-success((click)='approveToolCall(part.toolCall)')
                                i.fas.fa-check.me-1
                                | Approve
                            button.btn.btn-sm.btn-danger.ms-2((click)='rejectToolCall(part.toolCall)')
                                i.fas.fa-times.me-1
                                | Reject
                        .tool-status(*ngIf='part.toolCall.status !== "pending"')
                            span.badge.bg-success(*ngIf='part.toolCall.status === "approved"') Approved
                            span.badge.bg-danger(*ngIf='part.toolCall.status === "rejected"') Rejected
            
            ng-template(#simpleContent)
                .message-content(*ngIf='message.content') {{message.content}}

        .message.assistant-message(*ngIf='isLoading && currentMessageParts.length > 0')
            .message-header
                i.fas.fa-robot
                span.message-role Assistant
            
            ng-container(*ngFor='let part of currentMessageParts')
                .message-content(*ngIf='part.type === "text"') {{part.text}}
                .tool-execution(*ngIf='part.type === "tool-call" && part.toolCall')
                    .tool-header
                        i.fas.fa-terminal.me-2
                        strong Execute Shell Command
                    .tool-command
                        code {{part.toolCall.args.command}}
                    .tool-actions(*ngIf='part.toolCall.status === "pending"')
                        button.btn.btn-sm.btn-success((click)='approveToolCall(part.toolCall)')
                            i.fas.fa-check.me-1
                            | Approve
                        button.btn.btn-sm.btn-danger.ms-2((click)='rejectToolCall(part.toolCall)')
                            i.fas.fa-times.me-1
                            | Reject
                    .tool-status(*ngIf='part.toolCall.status !== "pending"')
                        span.badge.bg-success(*ngIf='part.toolCall.status === "approved"') Approved
                        span.badge.bg-danger(*ngIf='part.toolCall.status === "rejected"') Rejected
            
            .message-loading(*ngIf='isLoading')
                i.fas.fa-circle-notch.fa-spin

        .alert.alert-danger(*ngIf='error')
            i.fas.fa-exclamation-triangle.me-2
            | {{error}}

    .pilot-input
        textarea.form-control(
            #inputTextarea,
            [(ngModel)]='inputText',
            (keydown.enter)='handleEnterKey($event)',
            [disabled]='isLoading',
            placeholder='Type your message... (Enter to send, Shift+Enter for new line)',
            rows='3'
        )
        .pilot-input-actions
            button.btn.btn-primary((click)='sendMessage()', [disabled]='isLoading || !inputText.trim()')
                i.fas.fa-paper-plane.me-2(*ngIf='!isLoading')
                i.fas.fa-circle-notch.fa-spin.me-2(*ngIf='isLoading')
                | Send
            button.btn.btn-danger.ms-2((click)='stopResponse()', *ngIf='isLoading', title='Stop Response')
                i.fas.fa-stop.me-2
                | Stop
