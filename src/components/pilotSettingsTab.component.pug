h3
    i.fas.fa-robot.me-2
    | Pilot Settings

.form-line
    .header
        .title API Configuration
        .description Configure the provider used for new chats

.form-line
    .header
        .title Provider
        .description Select the API provider for new chat sessions
    select.form-control(
        [(ngModel)]='config.store.pilot.provider',
        (ngModelChange)='saveConfig()'
    )
        option(*ngFor='let provider of providerOptions', [value]='provider.value') {{provider.label}}

.form-line
    .header
        .title API Key
        .description API key for the selected provider
    input.form-control(
        type='password',
        [(ngModel)]='selectedProviderConfig.apiKey',
        (ngModelChange)='saveConfig()',
        [placeholder]='apiKeyPlaceholder'
    )

.form-line
    .header
        .title Base URL
        .description Optional custom API endpoint
    input.form-control(
        type='text',
        [(ngModel)]='selectedProviderConfig.baseURL',
        (ngModelChange)='saveConfig()',
        [placeholder]='baseURLPlaceholder'
    )

.form-line
    .header
        .title Model
        .description Enter the exact model ID to use
    input.form-control(
        type='text',
        [(ngModel)]='selectedProviderConfig.model',
        (ngModelChange)='saveConfig()',
        [placeholder]='modelPlaceholder'
    )

.form-line
    .header
        .title Temperature
        .description Controls randomness (0.0 - 1.0)
    input.form-control(
        type='number',
        min='0',
        max='1',
        step='0.1',
        [(ngModel)]='config.store.pilot.temperature',
        (ngModelChange)='saveConfig()'
    )

.form-line
    .header
        .title Max Tokens
        .description Maximum tokens in response
    input.form-control(
        type='number',
        min='256',
        max='8192',
        step='256',
        [(ngModel)]='config.store.pilot.maxTokens',
        (ngModelChange)='saveConfig()'
    )

.alert.alert-info.mt-3
    i.fas.fa-info-circle.me-2
    | Get your API key from 
    a([href]='providerHelpUrl', target='_blank') {{providerHelpLabel}}
